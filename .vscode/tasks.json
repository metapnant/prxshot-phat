{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build PSP Plugin (prxshot++)",
            "type": "shell",
            "command": "C:\\msys64\\msys2_shell.cmd",
            "args": [
                "-ucrt64",
                "-here",
                "-defterm",
                "-no-start",
                "-c",
                "export PSPDEV=/c/pspdev && export PATH=$PATH:$PSPDEV/bin && make"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}